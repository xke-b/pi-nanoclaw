

# Added by skill
ASSISTANT_HAS_OWN_NUMBER=

# Added by skill
TELEGRAM_BOT_TOKEN=

# Optional: SSH forwarding for container agents (allowlist)
# Comma-separated aliases the agent may SSH into.
# Supports alias mapping: alias=host-or-ip
# Examples:
#   SSH_ALLOWED_HOSTS=deepflame-1,build-server
#   SSH_ALLOWED_HOSTS=deepflame-1=10.0.0.15
# For plain aliases, NanoClaw reads HostName/User/Port/ProxyJump from SSH_CONFIG_PATH
SSH_ALLOWED_HOSTS=
# Optional defaults when not specified per-host in SSH config
SSH_DEFAULT_USER=
SSH_DEFAULT_PORT=
# Optional override for host SSH config and known_hosts paths
# SSH_CONFIG_PATH default: ~/.ssh/config
SSH_CONFIG_PATH=
# SSH_KNOWN_HOSTS_PATH default: ~/.ssh/known_hosts
SSH_KNOWN_HOSTS_PATH=
